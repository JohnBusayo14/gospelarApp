# Backend environment variables — copy to backend/.env and fill in real values.
# NEVER commit the real .env file.

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Two ways to configure the DB connection — pick ONE:
#
# (A) Cloud provider (Supabase, Railway, Render, Heroku, Neon, …):
#     Use the single DATABASE_URL connection string they give you.
#     SSL is enabled automatically. Comment out the DB_* lines below.
#
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxxx.supabase.co:5432/postgres
#
# (B) Local Postgres (development):
#     Set the individual vars below; leave DATABASE_URL unset/blank.
DB_USER=postgres
DB_PASSWORD=replace_with_real_password
DB_HOST=localhost
DB_NAME=gospeler
DB_PORT=5432

# ── Admin dashboard auth ─────────────────────────────────────────────────────
# Sent as `x-admin-key` header by the admin HTML; protects every /api/admin/*
# route. Use a long random string in production.


# ── Paystack ─────────────────────────────────────────────────────────────────
# Server-side secret used to verify transactions. Get it from your Paystack
# dashboard. Use the test key (sk_test_…) during development.

ADMIN_SECRET=replace_with_long_random_string
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Optional. If unset, all transactional emails (church approval / rejection)
# are silently skipped — the dashboard actions still succeed. Get a key from
# https://resend.com/api-keys.
RESEND_API_KEY=
# Sender address. Use 'onboarding@resend.dev' (Resend sandbox — only delivers
# to the Resend account owner) until you verify gospelar.com on Resend. Once
# verified, switch to: GOFAMINT Sunday School <noreply@gospelar.com>
MAIL_FROM=GOFAMINT Sunday School <noreply@gospelar.com>
# Optional. Public URL of the church-admin dashboard, included as a CTA in
# the approval email. Leave blank to omit the button.
CHURCH_ADMIN_URL=https://church.gospelar.com